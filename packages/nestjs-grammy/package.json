{
  "name": "@mdreal/nestjs-grammy",
  "version": "1.0.0",
  "description": "NestJS module for building Telegram bots with grammY. Supports multiple bots, decorators, injection, polling, and webhooks.",
  "keywords": [
    "nestjs",
    "telegram",
    "grammy",
    "bot",
    "decorators",
    "module"
  ],
  "homepage": "https://github.com/MDReal32/nestjs-grammy#readme",
  "bugs": {
    "url": "https://github.com/MDReal32/nestjs-grammy/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MDReal32/nestjs-grammy.git"
  },
  "license": "Apache-2.0",
  "author": "MDReal",
  "type": "module",
  "exports": {
    ".": {
      "types": "./build/nestjs-grammy.d.ts",
      "import": "./build/nestjs-grammy.js",
      "require": "./build/nestjs-grammy.cjs"
    },
    "./schematics": {}
  },
  "main": "./build/nestjs-grammy.cjs",
  "module": "./build/nestjs-grammy.js",
  "types": "./build/nestjs-grammy.d.ts",
  "files": [
    "build"
  ],
  "scripts": {
    "build": "vite build",
    "lint": "prettier --check \"src/**/*.ts\" \"*.{cjs,json,md,ts}\"",
    "prepack": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@grammyjs/runner": "^2.0.3",
    "@swc/helpers": "^0.5.19",
    "grammy": "^1.38.3",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@grammyjs/conversations": "^2.1.1",
    "@swc/core": "^1.15.18",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^24.10.1",
    "prettier": "^3.6.2",
    "prettier-plugin-packagejson": "^2.5.19",
    "typescript": "^5.8.3",
    "unplugin-swc": "^1.5.9",
    "vite": "^8.0.15",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "@grammyjs/conversations": "^2.0.0",
    "@nestjs/common": "^10 || ^11",
    "@nestjs/core": "^10 || ^11",
    "reflect-metadata": "^0.2"
  },
  "peerDependenciesMeta": {
    "@grammyjs/conversations": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
