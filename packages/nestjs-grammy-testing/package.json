{
  "name": "@mdreal/nestjs-grammy-testing",
  "version": "1.1.1",
  "description": "Testing utilities for NestJS applications built with @mdreal/nestjs-grammy.",
  "keywords": [
    "nestjs",
    "telegram",
    "grammy",
    "testing",
    "bot"
  ],
  "homepage": "https://github.com/MDReal32/nestjs-grammy#readme",
  "bugs": {
    "url": "https://github.com/MDReal32/nestjs-grammy/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MDReal32/nestjs-grammy.git",
    "directory": "packages/nestjs-grammy-testing"
  },
  "license": "Apache-2.0",
  "author": "MDReal",
  "type": "module",
  "exports": {
    ".": {
      "types": "./build/main.d.ts",
      "import": "./build/nestjs-grammy-testing.js"
    },
    "./jest": {
      "types": "./build/jest.d.ts",
      "import": "./build/jest.js"
    },
    "./vitest": {
      "types": "./build/vitest.d.ts",
      "import": "./build/vitest.js"
    },
    "./bun": {
      "types": "./build/bun.d.ts",
      "import": "./build/bun.js"
    },
    "./expect": {
      "types": "./build/expect.d.ts",
      "import": "./build/expect.js"
    },
    "./playwright": {
      "types": "./build/playwright.d.ts",
      "import": "./build/playwright.js"
    }
  },
  "module": "./build/nestjs-grammy-testing.js",
  "types": "./build/main.d.ts",
  "files": [
    "build",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "lint": "prettier --check \"src/**/*.ts\" \"*.{cjs,json,ts}\" \"README.md\"",
    "prepack": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@swc/helpers": "^0.5.19"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.1.24",
    "@nestjs/testing": "^11.0.1",
    "@playwright/test": "^1.61.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.10.1",
    "expect": "^30.4.1",
    "prettier": "^3.6.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typescript": "^5.8.3",
    "unplugin-swc": "^1.5.9",
    "vite": "^8.0.15",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "~4.1.7"
  },
  "peerDependencies": {
    "@mdreal/nestjs-grammy": "^1.0.0",
    "@nestjs/testing": "^10 || ^11",
    "@playwright/test": ">=1.30",
    "expect": ">=28",
    "vitest": ">=1"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    },
    "expect": {
      "optional": true
    },
    "vitest": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "nx": {
    "implicitDependencies": [
      "@mdreal/nestjs-grammy"
    ]
  }
}
