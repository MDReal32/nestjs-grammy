{
  "name": "@mdreal/monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "samples/*"
  ],
  "scripts": {
    "build": "pnpm --filter './packages/*' build",
    "format": "prettier --write .",
    "lint": "prettier --check .",
    "test": "pnpm --filter './packages/*' test",
    "typecheck": "pnpm --filter './packages/*' typecheck"
  },
  "dependencies": {
    "eslint": "^10.4.1",
    "typescript-eslint": "^8.60.0"
  },
  "devDependencies": {
    "@nx/eslint": "22.7.5",
    "@nx/vite": "22.7.5",
    "@nx/web": "22.7.5",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@vitest/ui": "~4.1.7",
    "jiti": "2.7.0",
    "nx": "22.7.5",
    "prettier": "^3.8.3",
    "prettier-plugin-packagejson": "^3.0.2",
    "vite": "^8.0.15",
    "vitest": "~4.1.7"
  },
  "packageManager": "yarn@4.15.0",
  "engines": {
    "node": ">=22"
  }
}
